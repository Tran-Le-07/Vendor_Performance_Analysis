      <aliases enabled='yes' />
      <column caption='Actual Price' datatype='real' name='[ActualPrice]' role='measure' type='quantitative' />
      <column aggregation='Sum' datatype='integer' name='[Brand]' role='dimension' type='ordinal' />
      <column caption='purchasecontribution' datatype='real' name='[Calculation_2323798385582082]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPurchaseDollars]) / TOTAL(SUM([TotalPurchaseDollars]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='top 10 %contribution' datatype='real' name='[Calculation_2323798555258887]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([TotalPurchaseDollars]) / MIN({ SUM([TotalPurchaseDollars]) })' />
      </column>
      <column caption='shorter name' datatype='string' name='[Calculation_2323798563864584]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([VendorName], 5) + &quot;...&quot;' />
      </column>
      <column caption='shorter brand' datatype='string' name='[Calculation_2323798593966090]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Description], 5) + &quot;...&quot;' />
      </column>
      <column caption='performance status' datatype='string' name='[Calculation_2323798596849675]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [ProfitMargin] &lt; 0.20 AND [TotalSalesDollars] &lt; 500000 &#10;THEN &quot;Low Performing&quot; &#10;ELSE &quot;Standard&quot; &#10;END' />
      </column>
      <column caption='TargetBrand' datatype='string' name='[Calculation_2323798627463181]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([TotalSalesDollars]) &lt;= ATTR({FIXED : PERCENTILE([TotalSalesDollars], 0.15)})&#10;AND AVG([ProfitMargin]) &gt;= ATTR({FIXED : PERCENTILE([ProfitMargin], 0.85)})&#10;THEN &apos;yes&apos;&#10;ELSE &apos;no&apos;&#10;END' />
      </column>
      <column caption='short name' datatype='string' name='[Calculation_2323798656204814]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([VendorName], 20) + &quot;...&quot;' />
      </column>
